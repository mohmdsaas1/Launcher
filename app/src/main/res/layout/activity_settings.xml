<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111111"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="نمط العرض"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginTop="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnFixedGrid"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="شبكة ثابتة" />

            <Button
                android:id="@+id/btnTabs"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="تبويبات" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="الخلفية"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginTop="24dp" />

        <Button
            android:id="@+id/btnChooseWallpaper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="اختر خلفية من المعرض" />

        <Button
            android:id="@+id/btnResetWallpaper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="رجّع الخلفية الافتراضية" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="عدد الأعمدة"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginTop="24dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button android:id="@+id/btnColumns3" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="3" />
            <Button android:id="@+id/btnColumns4" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="4" />
            <Button android:id="@+id/btnColumns5" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="5" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="حجم الأيقونة"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginTop="24dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button android:id="@+id/btnIconSmall" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="صغير" />
            <Button android:id="@+id/btnIconMedium" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="متوسط" />
            <Button android:id="@+id/btnIconLarge" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="كبير" />
        </LinearLayout>

        <Switch
            android:id="@+id/switchShowLabels"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="إظهار اسم التطبيق"
            android:textColor="#FFFFFF" />

        <Switch
            android:id="@+id/switchGroupByCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="تجميع حسب الفئة (تواصل، ترفيه...)"
            android:textColor="#FFFFFF" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:textColor="#999999"
            android:textSize="12sp"
            android:text="تثبيت تطبيق أو استبعاده من الترتيب: اضغط ضغطة مطوّلة على أي أيقونة بالشاشة الرئيسية. تجميد قسم: اضغط أيقونة القفل فوق القسم." />

        <Button
            android:id="@+id/btnDone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="تم" />

    </LinearLayout>
</ScrollView>
